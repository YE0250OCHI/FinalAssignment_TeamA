@page
@model HistoryModel

<div class="container my-4" style="max-width: 500px;">
    <div class="d-flex justify-content-between align-items-center border-bottom border-primary border-2 pb-2 mb-4">
        <h2 class="text-primary fs-3 fw-bold m-0">出庫依頼履歴</h2>
        <div class="fs-3" style="cursor: pointer;">&#9776;</div>
    </div>

    <form method="get" class="mb-4">
        <div class="row g-2 align-items-center mb-2">
            <div class="col-5">
                <input type="date" asp-for="taskEndDateFrom" class="form-control form-control-sm border-dark shadow-sm" />
            </div>
            <div class="col-1 text-center">～</div>
            <div class="col-5">
                <input type="date" asp-for="taskEndDateTo" class="form-control form-control-sm border-dark shadow-sm" />
            </div>
        </div>

        <div class="row g-2 align-items-center mb-3">
            <div class="col-8">
                <select asp-for="sort" class="form-select form-select-sm border-dark shadow-sm" onchange="this.form.submit()">
                    <option value="latest">最新</option>
                    <option value="oldest">古い順</option>
                </select>
            </div>
            <div class="col-4 text-end">
                <button type="submit" class="btn btn-primary btn-sm fw-bold w-100 shadow-sm">更新</button>
            </div>
        </div>
    </form>

    <div class="card bg-light rounded-4 p-3 border-secondary border-opacity-25">
        <div class="d-flex flex-column gap-2">
            @foreach (var item in Model.FinishedTaskList)
            {
                // ④ ステータスごとの色分け設定
                string bgClass = item.status == "キャンセル" ? "bg-secondary" : (item.status == "完了" ? "bg-warning" : "bg-danger");
                string textClass = item.status == "キャンセル" ? "text-secondary" : (item.status == "完了" ? "text-warning" : "text-danger");

                <div class="d-flex justify-content-between align-items-center @bgClass bg-opacity-10 border @bgClass border-opacity-50 rounded-3 p-2 ps-3">
                    <div class="d-flex align-items-center flex-grow-1">
                        <span class="@textClass fw-bold me-3" style="min-width: 70px;">@item.status</span>
                        <span class="fw-bold me-2">@item.name</span>
                    </div>
                    <div class="text-secondary small text-end text-nowrap">
                        完了日：@item.finishedAt.ToString("yyyy/MM/dd HH:mm")
                    </div>
                </div>
            }
            
            @if (!Model.FinishedTaskList.Any())
            {
                <div class="text-center text-secondary py-3 small">対象の履歴はありません。</div>
            }
        </div>
    </div>
</div>