@page "/picking-orders/{jobId?}"
@model IndexModel

@{
    ViewData["Title"] = "出庫依頼一覧";

}

<div class="card bg-light rounded-4 p-3 mb-4 border-secondary border-opacity-25">

    <h5 class="fw-bold fs-6 mb-1">
        出庫依頼新規作成
    </h5>

    <!-- エラーメッセージ表示 -->
    <div id="errorMessage"
         class="text-danger small mb-2"
         style="white-space: pre-line;">
    </div>

    <form method="post"
          asp-page-handler="AddOrder"
          class="d-flex gap-2">

        <select asp-for="SelectedItem"
                asp-items="@Model.ItemList"
                class="form-select border-dark shadow-sm"
                required>

            <option value="">
                -- 部品を選択してください --
            </option>

        </select>

        <button type="submit"
                class="btn btn-primary fw-bold px-3 shadow-sm">

            追加

        </button>

    </form>

</div>


<div class="card bg-light rounded-4 p-3 border-secondary border-opacity-25">

    <h5 class="fw-bold fs-6 mb-3">
        未完了出庫依頼一覧
    </h5>

    <div class="d-flex flex-column gap-2"
         id="incompleteTaskListContainer">

        <!-- 未完了タスクコンテナ -->

    </div>

</div>


<!-- ========================= -->
<!-- エラーモーダル -->
<!-- ========================= -->

<div class="modal fade"
     id="errorModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog
        modal-dialog-centered
        modal-sm">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    エラー
                </h5>

            </div>

            <div class="modal-body text-center"
                 style="white-space: pre-line;">

                @Model.ErrorMessage

            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-primary"
                        data-bs-dismiss="modal">

                    確認

                </button>

            </div>

        </div>

    </div>

</div>


<!-- ========================= -->
<!-- モーダル表示制御 -->
<!-- ========================= -->
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            const modal =
                new bootstrap.Modal(
                    document.getElementById('errorModal'));

            modal.show();

        });
    </script>
}